datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model Participant {
  id              String   @id @default(cuid())
  nombre          String
  apellido        String
  alias           String
  email           String   @unique
  telefono        String
  instagram       String
  fechaNacimiento DateTime
  edad            Int      @default(0)
  aceptaTerminos  Boolean  @default(false)
  sigueCuenta     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  video           Video?

  @@index([email])
  @@map("participants")
}

enum VideoStatus {
  PENDING_UPLOAD
  PENDING_VALIDATION
  VALIDATED
  REJECTED
}

model Video {
  id            String  @id @default(cuid())
  participantId String  @unique
  fileName      String
  storageKey    String
  url           String? @db.Text
  format        String?
  fileSize      Int
  fps           Int?

  // CAMPOS DE PRODUCCIÓN (RECUPERADOS)
  closingLikes      Int?
  closingLikesAt    DateTime? // NUEVO: Agregado para soportar likes-closing
  duration          Float?
  isJudgeSelected   Boolean      @default(false)
  resolution        String?
  status            VideoStatus  @default(PENDING_UPLOAD)
  validationResult  Json?
  rejectionReason   String?
  uploadedAt        DateTime     @default(now())
  validatedAt       DateTime?
  instagramUrl      String?
  instagramLikes    Int          @default(0)
  lastInstagramSync DateTime?
  participant       Participant  @relation(fields: [participantId], references: [id], onDelete: Cascade)
  evaluations       Evaluation[]

  @@index([participantId])
  @@index([status])
  @@map("videos")
}

model Judge {
  id                String       @id @default(cuid())
  nombre            String
  apellido          String?
  profesion         String?
  biografia         String?      @db.Text
  fotoUrl           String?      @db.Text
  email             String       @unique
  telefono          String?
  instagram         String?
  password          String?
  role              String       @default("JUDGE")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @default(now()) @updatedAt
  isDefaultPassword Boolean      @default(true)
  resetRequested    Boolean      @default(false)
  evaluations       Evaluation[]

  @@index([email])
  @@map("judges")
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  severity    String   @default("INFO")
  issuer      String?
  ipAddress   String?
  userAgent   String?
  targetId    String?
  targetEmail String?
  targetName  String?
  details     String?
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([severity])
  @@map("audit_logs")
}

model EvaluationCriterion {
  id              String           @id @default(cuid())
  nombre          String
  descripcion     String?
  peso            Float
  puntajeMaximo   Float            @default(20.0)
  orden           Int
  createdAt       DateTime         @default(now())
  criterionScores CriterionScore[]

  @@index([orden])
  @@map("evaluation_criteria")
}

model Evaluation {
  id                     String           @id @default(cuid())
  videoId                String
  judgeId                String
  observacionesGenerales String?
  puntajeTotal           Float
  evaluatedAt            DateTime         @default(now())
  video                  Video            @relation(fields: [videoId], references: [id], onDelete: Cascade)
  judge                  Judge            @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  criterionScores        CriterionScore[]

  @@unique([videoId, judgeId])
  @@index([videoId])
  @@index([judgeId])
  @@map("evaluations")
}

model CriterionScore {
  id            String              @id @default(cuid())
  evaluationId  String
  criterionId   String
  puntaje       Float
  observaciones String?
  evaluation    Evaluation          @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  criterion     EvaluationCriterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, criterionId])
  @@index([evaluationId])
  @@map("criterion_scores")
}

model Admin {
  id        String   @id @default(cuid())
  nombre    String
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())

  @@index([email])
  @@map("admins")
}

model ContestSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("contest_settings")
}

model InstagramConfig {
  id                     Int      @id @default(autoincrement())
  storyHours             String   @default("08:00,20:00")
  feedHours              String   @default("12:00")
  participationMsgs      String   @db.Text
  votingMsgs             String   @db.Text
  restrictToOfficialGrid Boolean  @default(true)
  designMode             String   @default("auto") // "auto" | "custom"
  customStoryBg          String?  @db.Text
  customFeedBg           String?  @db.Text
  timerFormat            String?  @default("d-h")
  updatedAt              DateTime @updatedAt

  @@map("instagram_configs")
}

enum CategoriaVideo {
  RENDER
  IA
  AMBAS
}

enum EstatusInscripcion {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum EstatusToken {
  PENDIENTE
  USADO
  EXPIRADO
}

enum EstatusPago {
  EN_REVISION
  VALIDADO
  RECHAZADO
}

enum EstatusRevision {
  RECIBIDO
  APROBADO
  RECHAZADO
}

model InscripcionCopa2026 {
  id                 Int                @id @default(autoincrement())
  cedulaIdentidad    String             @db.VarChar(12)
  nombre             String             @db.VarChar(100)
  apellido           String             @db.VarChar(100)
  telefono           String             @db.VarChar(15)
  email              String             @db.VarChar(150)
  categoria          CategoriaVideo
  tokenVideo         String             @unique @db.VarChar(36)
  tokenExpiry        DateTime
  estatusToken       EstatusToken       @default(PENDIENTE)
  estatusInscripcion EstatusInscripcion @default(PENDIENTE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  pago               PagoMovil?
  videos             VideoCopa2026[]

  @@unique([cedulaIdentidad, categoria])
  @@unique([email, categoria])
  @@map("inscripciones_copa2026")
}

model PagoMovil {
  id                Int                 @id @default(autoincrement())
  inscripcionId     Int                 @unique
  inscripcion       InscripcionCopa2026 @relation(fields: [inscripcionId], references: [id])
  bancoOrigenCodigo String              @db.VarChar(4)
  telefonoPago      String              @db.VarChar(15)
  referencia        String              @db.VarChar(50)
  montoCapturadoBs  Decimal             @db.Decimal(12, 2)
  montoEsperadoBs   Decimal             @db.Decimal(12, 2)
  tasaBcvUsada      Decimal             @db.Decimal(10, 4)
  fechaPagoExtractada DateTime?
  comprobantePath   String              @db.VarChar(500)
  ocrResultadoRaw   Json?
  ocrConfianza      Float?
  estatusPago       EstatusPago         @default(EN_REVISION)
  createdAt         DateTime            @default(now())

  @@map("pagos_movil")
}

model VideoCopa2026 {
  id            Int                 @id @default(autoincrement())
  inscripcionId Int
  inscripcion   InscripcionCopa2026 @relation(fields: [inscripcionId], references: [id])
  rutaS3        String              @db.VarChar(500)
  nombreArchivo String              @db.VarChar(255)
  tamanoBytes   BigInt
  duracionSeg   Int?
  resolucion    String?             @db.VarChar(20)
  fps           Float?
  formato       String?             @db.VarChar(20)
  warnings      Json?
  estatus       EstatusRevision     @default(RECIBIDO)
  createdAt     DateTime            @default(now())
  votos         Voto[]

  @@map("videos_copa2026")
}

model Votante {
  id                Int      @id @default(autoincrement())
  cedulaVotante     String   @unique @db.VarChar(12)
  telefonoVotante   String   @unique @db.VarChar(15)
  deviceFingerprint String   @db.VarChar(64)
  createdAt         DateTime @default(now())
  votos             Voto[]

  @@map("votantes")
}

model Voto {
  id              Int           @id @default(autoincrement())
  votanteId       Int
  votante         Votante       @relation(fields: [votanteId], references: [id])
  videoCopa2026Id Int
  video           VideoCopa2026 @relation(fields: [videoCopa2026Id], references: [id])
  seqGeneral      Int
  seqPorVideo     Int
  createdAt       DateTime      @default(now())

  @@unique([votanteId, videoCopa2026Id])
  @@map("votos")
}

model TasaBcvHistorico {
  id        Int      @id @default(autoincrement())
  fecha     DateTime @unique @db.Date
  tasaUsdBs Decimal  @db.Decimal(10, 4)
  fuenteUrl String?  @db.VarChar(255)
  createdAt DateTime @default(now())

  @@map("tasa_bcv_historico")
}

model Banco {
  id     Int     @id @default(autoincrement())
  codigo String  @unique @db.VarChar(4)
  nombre String  @db.VarChar(100)
  activo Boolean @default(true)

  @@map("bancos")
}

model ConfigConcurso {
  id          Int      @id @default(autoincrement())
  clave       String   @unique @db.VarChar(100)
  valor       String   @db.Text
  descripcion String?  @db.VarChar(255)
  updatedAt   DateTime @updatedAt

  @@map("config_concurso")
}

model PlantillaEmail {
  id            Int      @id @default(autoincrement())
  tipo          String   @unique @db.VarChar(50) // BIENVENIDA, VIDEO_RECIBIDO
  asunto        String   @db.VarChar(255)
  contenidoHtml String   @db.Text
  updatedAt     DateTime @updatedAt

  @@map("plantillas_email")
}

model EmailLog {
  id          Int      @id @default(autoincrement())
  resendId    String?  @unique @db.VarChar(100)
  to          String   @db.VarChar(150)
  subject     String   @db.VarChar(255)
  tipo        String   @db.VarChar(50)
  status      String   @default("ENVIADO") @db.VarChar(20)
  createdAt   DateTime @default(now())
  deliveredAt DateTime?
  openedAt    DateTime?

  @@map("email_logs")
}
